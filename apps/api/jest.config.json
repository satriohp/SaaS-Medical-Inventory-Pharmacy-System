{
    "moduleFileExtensions": [
        "js",
        "json",
        "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
        "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
        "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node",
    "roots": [
        "<rootDir>",
        "../test"
    ],
    "testPathIgnorePatterns": [
        "/node_modules/",
        "/dist/"
    ],
    "coverageThreshold": {
        "global": {
            "branches": 60,
            "functions": 70,
            "lines": 70
        }
    }
}